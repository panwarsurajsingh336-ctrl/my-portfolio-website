      ] %>
      <% values.forEach(function(v) { %>
      <div class="col-md-6 col-lg-3 reveal">
        <div class="value-card">
          <div class="value-card__icon">
            <i class="<%= v.icon %>"></i>
          </div>
          <h5 class="value-card__title"><%= v.title %></h5>
          <p class="value-card__desc"><%= v.desc %></p>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
