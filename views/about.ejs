      <% const values = [
        { icon: 'fa-solid fa-layer-group', title: 'Full-Stack Thinking', desc: 'I connect frontend UX, backend APIs, and databases into complete working features.' },
        { icon: 'fa-solid fa-chart-pie', title: 'Data-Driven Work', desc: 'I use Python, Excel, SQL, and Power BI to turn raw data into understandable insights.' },
